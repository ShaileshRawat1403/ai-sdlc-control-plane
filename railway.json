{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "watchPatterns": ["**/*.ts", "package.json", "tsconfig.json", "state/**/*.yml", "dashboard/**/*.md"]
  },
  "deploy": {
    "startCommand": "bun run systems/toolsmith/scripts/telegram-bot.ts",
    "restartPolicyType": "ALWAYS"
  }
}
